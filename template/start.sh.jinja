#!/bin/bash
# Start {{ project_name }} platform
# Usage: ./start.sh [--refresh]
#   --refresh   fast-forward stellars-jupyterhub-ds clone to upstream/main
#               AND pull latest docker images. Without --refresh the script
#               uses whatever is on disk (after a one-time clone of the
#               upstream platform on first run).
#
# The upstream stellars-jupyterhub-ds/ clone is meant to be read-only. If
# it has local modifications, start.sh refuses to run regardless of
# --refresh - revert or upstream the changes first.

set -e

cd "$(dirname "$0")"

REFRESH=0
for arg in "$@"; do
    case "$arg" in
        --refresh) REFRESH=1 ;;
        *) echo "Unknown option: $arg" >&2; exit 2 ;;
    esac
done

# Load defaults, then local overrides
source env.default
if [[ -f .env ]]; then
    source .env
fi

# Bootstrap self-signed TLS cert on first run.
# Traefik's file provider watches certs/ for tls.yml; if it is not present,
# call certs_generate.sh with no args (sources certs/certs.params for CN +
# altnames). Skip silently on subsequent runs.
if [[ ! -f certs/tls.yml ]]; then
    if [[ ! -f certs/certs_generate.sh ]]; then
        echo "ERROR: certs/certs_generate.sh not found - cannot bootstrap TLS cert." >&2
        echo "       Re-run 'copier copy --trust' or 'copier update --trust' to render it." >&2
        exit 1
    fi
    echo "No TLS cert found in certs/ - generating from certs/certs.params..."
    (cd certs && bash certs_generate.sh)
    if [[ ! -f certs/tls.yml ]]; then
        echo "ERROR: cert generation completed but certs/tls.yml was not produced." >&2
        exit 1
    fi
fi

# Upstream platform location. Three supported shapes:
#   1. git    - a regular git clone (default; what we clone if $SUB is missing)
#   2. submodule - a git submodule of a parent repo (.git is a gitlink file)
#   3. standalone - operator-placed content with no git tracking at all
# The overlay treats $SUB as read-only - we never modify its contents, only
# refresh on --refresh when it is git-managed. Listed in .gitignore so the
# rendered overlay never tracks its contents.
SUB="stellars-jupyterhub-ds"
SUB_URL="https://github.com/stellarshenson/stellars-jupyterhub-ds.git"
SUB_BRANCH="main"

# Classify $SUB into one of: git | submodule | standalone | missing.
sub_kind() {
    if   [[ ! -d "$SUB"     ]]; then echo missing
    elif [[ -d "$SUB/.git"  ]]; then echo git
    elif [[ -f "$SUB/.git"  ]]; then echo submodule
    else                             echo standalone
    fi
}

# One-time clone on first run if the directory is missing entirely.
if [[ "$(sub_kind)" == "missing" ]]; then
    echo "Cloning $SUB (branch $SUB_BRANCH)..."
    git clone --branch "$SUB_BRANCH" "$SUB_URL" "$SUB"
fi

# Without --refresh: use whatever is on disk. We do NOT police the upstream
# tree's working state - operators may legitimately have local modifications
# (especially in submodule mode where the parent repo tracks a custom commit
# or a patched build). Only --refresh would mutate the tree, so the dirty-
# tree guard is gated on that flag below.

# Refresh from upstream only when explicitly asked. Behaviour per shape:
#   - git       : fetch + rebase onto the configured upstream (origin/main
#                 by default; respects operator's fork if origin was retargeted)
#   - submodule : same fetch + rebase inside the submodule, plus a notice
#                 that the parent repo's submodule pointer needs updating
#                 separately for the change to be tracked there
#   - standalone: refresh is meaningless; print a notice and continue
if [[ "$REFRESH" == "1" ]]; then
    case "$(sub_kind)" in
        git|submodule)
            kind=$(sub_kind)
            # Only NOW does the dirty-tree guard apply: --refresh would
            # rebase, which would clobber/conflict with local modifications.
            if [[ -n "$(git -C "$SUB" status --porcelain)" ]]; then
                echo "ERROR: $SUB has local modifications; --refresh would overwrite them." >&2
                echo "       Commit or revert the changes (git -C $SUB checkout .) or omit --refresh to use the tree as-is." >&2
                git -C "$SUB" status --short >&2
                exit 1
            fi
            upstream=$(git -C "$SUB" rev-parse --abbrev-ref '@{u}' 2>/dev/null || echo "origin/$SUB_BRANCH")
            remote="${upstream%%/*}"
            echo "Refreshing $SUB ($kind) - fetch + rebase onto $upstream..."
            git -C "$SUB" fetch "$remote"
            git -C "$SUB" rebase "$upstream"
            if [[ "$kind" == "submodule" ]]; then
                echo "Note: parent repo's submodule pointer is unchanged; from the parent run:"
                echo "      git submodule update --remote --rebase $SUB"
            fi
            ;;
        standalone)
            echo "Note: $SUB is standalone (no git tracking); --refresh has no effect."
            ;;
    esac
fi

# Build compose command
COMPOSE_FILES="--env-file env.default"
if [[ -f .env ]]; then
    COMPOSE_FILES="${COMPOSE_FILES} --env-file .env"
fi
COMPOSE_FILES="${COMPOSE_FILES} -f stellars-jupyterhub-ds/compose.yml -f compose_override.yml"
{%- if cifs_shared_mount %}
if [[ "${ENABLE_CIFS}" == "1" ]]; then
    echo "CIFS mount enabled"
    COMPOSE_FILES="${COMPOSE_FILES} -f compose_cifs.yml"
fi
{%- endif %}

# Docker image pull is also gated by --refresh; without it, reuse whatever
# images are already on the host (faster startup, no network round-trip).
if [[ "$REFRESH" == "1" ]]; then
    echo "Pulling latest images..."
    docker compose ${COMPOSE_FILES} pull --ignore-pull-failures
fi

echo "Starting {{ project_name }} platform..."
docker compose ${COMPOSE_FILES} up -d --no-build

echo "Done. Access: https://${JUPYTERHUB_PREFIX:-{% if jupyterhub_subdomain %}{{ jupyterhub_subdomain }}.{% endif %}}${BASE_HOSTNAME:-{{ base_hostname }}}/"
