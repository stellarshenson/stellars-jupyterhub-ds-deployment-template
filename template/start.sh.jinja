#!/bin/bash
# Start {{ project_name }} platform
# Usage: ./start.sh [--refresh]
#   --refresh   fast-forward stellars-jupyterhub-ds clone to upstream/main
#               AND pull latest docker images. Without --refresh the script
#               uses whatever is on disk (after a one-time clone of the
#               upstream platform on first run).
#
# The upstream stellars-jupyterhub-ds/ clone is meant to be read-only. If
# it has local modifications, start.sh refuses to run regardless of
# --refresh - revert or upstream the changes first.

set -e

cd "$(dirname "$0")"

REFRESH=0
for arg in "$@"; do
    case "$arg" in
        --refresh) REFRESH=1 ;;
        *) echo "Unknown option: $arg" >&2; exit 2 ;;
    esac
done

# Load defaults, then local overrides
source env.default
if [[ -f .env ]]; then
    source .env
fi

# Bootstrap self-signed TLS cert on first run.
# Traefik's file provider watches certs/ for tls.yml; if it is not present,
# call certs_generate.sh with no args (sources certs/certs.params for CN +
# altnames). Skip silently on subsequent runs.
if [[ ! -f certs/tls.yml ]]; then
    if [[ ! -f certs/certs_generate.sh ]]; then
        echo "ERROR: certs/certs_generate.sh not found - cannot bootstrap TLS cert." >&2
        echo "       Re-run 'copier copy --trust' or 'copier update --trust' to render it." >&2
        exit 1
    fi
    echo "No TLS cert found in certs/ - generating from certs/certs.params..."
    (cd certs && bash certs_generate.sh)
    if [[ ! -f certs/tls.yml ]]; then
        echo "ERROR: cert generation completed but certs/tls.yml was not produced." >&2
        exit 1
    fi
fi

# Upstream platform clone (NOT a git submodule). Treated as read-only:
# this overlay never modifies its contents, only refreshes from origin/main
# when explicitly asked via --refresh.
# Listed in .gitignore so it does not appear in this repo's index.
SUB="stellars-jupyterhub-ds"
SUB_URL="https://github.com/stellarshenson/stellars-jupyterhub-ds.git"
SUB_BRANCH="main"

# One-time clone on first run if the directory is missing.
if [[ ! -d "$SUB/.git" ]]; then
    echo "Cloning $SUB (branch $SUB_BRANCH)..."
    git clone --branch "$SUB_BRANCH" "$SUB_URL" "$SUB"
fi

# The upstream clone must stay clean. Refuse to start if it was edited
# locally - regardless of --refresh - so we never silently overwrite
# in-progress upstream work.
if [[ -n "$(git -C "$SUB" status --porcelain)" ]]; then
    echo "ERROR: $SUB has local modifications; this directory is meant to be read-only." >&2
    echo "       Revert the changes (git -C $SUB checkout .) or move them upstream before re-running." >&2
    git -C "$SUB" status --short >&2
    exit 1
fi

# Fast-forward only when explicitly asked.
if [[ "$REFRESH" == "1" ]]; then
    echo "Refreshing $SUB (fast-forward only)..."
    git -C "$SUB" pull --ff-only origin "$SUB_BRANCH"
fi

# Build compose command
COMPOSE_FILES="--env-file env.default"
if [[ -f .env ]]; then
    COMPOSE_FILES="${COMPOSE_FILES} --env-file .env"
fi
COMPOSE_FILES="${COMPOSE_FILES} -f stellars-jupyterhub-ds/compose.yml -f compose_override.yml"
{%- if cifs_shared_mount %}
if [[ "${ENABLE_CIFS}" == "1" ]]; then
    echo "CIFS mount enabled"
    COMPOSE_FILES="${COMPOSE_FILES} -f compose_cifs.yml"
fi
{%- endif %}

# Docker image pull is also gated by --refresh; without it, reuse whatever
# images are already on the host (faster startup, no network round-trip).
if [[ "$REFRESH" == "1" ]]; then
    echo "Pulling latest images..."
    docker compose ${COMPOSE_FILES} pull --ignore-pull-failures
fi

echo "Starting {{ project_name }} platform..."
docker compose ${COMPOSE_FILES} up -d --no-build

echo "Done. Access: https://${JUPYTERHUB_PREFIX:-{% if jupyterhub_subdomain %}{{ jupyterhub_subdomain }}.{% endif %}}${BASE_HOSTNAME:-{{ base_hostname }}}/"
