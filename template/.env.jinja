# Local overrides for the {{ project_name }} deployment - takes precedence over env.default.
# This file is gitignored. Edit it for your local deployment without modifying
# the tracked env.default.

# Optional INITIAL admin password for JUPYTERHUB_ADMIN={{ admin_username }}.
#
# When set, the hub pre-creates the admin UserInfo with this password on first
# startup (seeds a bcrypt hash). Once the admin changes their password through
# the UI, this env value is permanently ignored.
#
# When unset (default), a fresh database opens a one-time signup window scoped
# to '{{ admin_username }}' only - sign up at /hub/signup with any password
# you choose, and NativeAuthenticator self-approves the bootstrap.
#
#JUPYTERHUB_ADMIN_PASSWORD=
