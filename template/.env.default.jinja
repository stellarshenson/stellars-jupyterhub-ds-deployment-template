# Default environment variables for {{ project_name }} JupyterHub deployment.
# Override in .env (not tracked by git).
COMPOSE_PROJECT_NAME={{ project_slug }}

# Domain for Traefik routing
BASE_HOSTNAME={{ base_hostname }}

# JupyterHub subdomain prefix (set empty to serve at root domain)
JUPYTERHUB_PREFIX={{ jupyterhub_subdomain_prefix }}

# Enable CIFS mount for shared storage (0=disabled, 1=enabled)
ENABLE_CIFS={% if cifs_shared_mount %}0{% else %}0{% endif %}
