# =============================================================================
# Compose Override - {{ project_name }}
# Local Traefik with self-signed certificates and {{ project_name }} branding.
# =============================================================================
#
# PORTS:  80 (HTTP -> redirects to 443)  |  443 (HTTPS)
# CERT:   Self-signed cert in ./certs/
# ACCESS: https://${JUPYTERHUB_PREFIX}${BASE_HOSTNAME}/
#
# Set BASE_HOSTNAME and JUPYTERHUB_PREFIX in .env.
# =============================================================================

services:

  traefik:
    image: traefik:latest
    command:
      # Entrypoints
      - "--entrypoints.web.address=:80"
      - "--entrypoints.websecure.address=:443"
      - "--entrypoints.websecure.http.tls=true"

      # Docker provider
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"

      # File provider for TLS certificates
      - "--providers.file.directory=/certs"
      - "--providers.file.watch=true"

      # API and Dashboard
      - "--api.dashboard=true"
      - "--api.insecure=false"

      # TLS configuration
      - "--serverstransport.insecureskipverify=true"

      # Logging
      - "--log.level=INFO"
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ../certs:/certs:ro
    networks:
      - jupyterhub_network
    labels:
      - "traefik.enable=true"

      # Global HTTP->HTTPS redirect
      - "traefik.http.routers.http-catchall.rule=HostRegexp(`.+`)"
      - "traefik.http.routers.http-catchall.entrypoints=web"
      - "traefik.http.routers.http-catchall.middlewares=redirect-to-https"
      - "traefik.http.routers.http-catchall.priority=1"
      - "traefik.http.middlewares.redirect-to-https.redirectscheme.scheme=https"
      - "traefik.http.middlewares.redirect-to-https.redirectscheme.permanent=true"

      # Dashboard: traefik.${BASE_HOSTNAME}
      - "traefik.http.routers.dashboard.rule=Host(`traefik.${BASE_HOSTNAME}`) || HostRegexp(`^traefik(\\..+)?\\.localhost$`)"
      - "traefik.http.routers.dashboard.entrypoints=websecure"
      - "traefik.http.routers.dashboard.tls=true"
      - "traefik.http.routers.dashboard.service=api@internal"
    restart: unless-stopped

  jupyterhub:
    ports: []
    environment:
      # main settings
      - JUPYTERHUB_BASE_URL=/
      - JUPYTERHUB_ADMIN={{ admin_username }} # initial admin username
      - JUPYTERHUB_ADMIN_PASSWORD=${JUPYTERHUB_ADMIN_PASSWORD:-} # optional INITIAL admin password from .env; ignored once admin sets one in the UI
      - JUPYTERHUB_IDLE_CULLER_ENABLED={% if idle_culler_enabled %}1{% else %}0{% endif %} # culler 0=disabled, 1=enabled
      - JUPYTERHUB_IDLE_CULLER_MAX_EXTENSION=48 # max hours users can extend session
      - JUPYTERHUB_SIGNUP_ENABLED={% if signup_enabled %}1{% else %}0{% endif %} # user self-registration: 0=disabled, 1=enabled
      - JUPYTERHUB_NOTEBOOK_IMAGE=stellars/stellars-jupyterlab-ds:latest # user container image
      - JUPYTERHUB_TIMEZONE={{ timezone }} # timezone for hub and lab

      # branding ({{ project_name }})
      - JUPYTERHUB_LOGO_URI=file:///srv/branding/{{ branding_prefix }}_logo.png
      - JUPYTERHUB_FAVICON_URI=file:///srv/branding/favicon.ico
      - JUPYTERHUB_LAB_MAIN_ICON_URI=file:///srv/branding/{{ branding_prefix }}_main_icon.svg
      - JUPYTERLAB_SYSTEM_NAME={{ project_name }}
      - JUPYTERLAB_HEADER_CAPITALIZE_SYSTEM_NAME=1
    volumes:
      - ../branding:/srv/branding:ro
    networks:
      - jupyterhub_network
    labels:
      - "traefik.enable=true"

      # JupyterHub router
      - "traefik.http.routers.jupyterhub-rtr.rule=Host(`${JUPYTERHUB_PREFIX}${BASE_HOSTNAME}`) || HostRegexp(`^${JUPYTERHUB_PREFIX}(.*\\.)?localhost$`)"
      - "traefik.http.routers.jupyterhub-rtr.entrypoints=websecure"
      - "traefik.http.routers.jupyterhub-rtr.tls=true"
      - "traefik.http.routers.jupyterhub-rtr.service=jupyterhub-svc"
      - "traefik.http.services.jupyterhub-svc.loadbalancer.server.scheme=http"
      - "traefik.http.services.jupyterhub-svc.loadbalancer.server.port=8000"

  watchtower:
    networks:
      - jupyterhub_network

networks:
  jupyterhub_network:
    name: ${COMPOSE_PROJECT_NAME:-jupyterhub}_network  # actual Docker network name namespaced by compose project

# EOF
